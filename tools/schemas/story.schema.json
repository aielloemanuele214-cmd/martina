{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "eventi",
    "scene",
    "dialoghi",
    "segreti",
    "finali",
    "ui"
  ],
  "properties": {
    "eventi": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "quando",
          "fai"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "quando": {
            "type": "string",
            "pattern": "^interagisci:"
          },
          "se": {},
          "fai": {
            "type": "array",
            "items": {
              "type": "object",
              "minProperties": 1
            }
          },
          "altrimenti": {
            "type": "array",
            "items": {
              "type": "object",
              "minProperties": 1
            }
          }
        }
      }
    },
    "scene": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "passi"
        ],
        "properties": {
          "passi": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "minProperties": 1
            }
          }
        }
      }
    },
    "dialoghi": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "nome"
        ],
        "properties": {
          "nome": {
            "type": "string"
          },
          "modo": {
            "enum": [
              "sacchetto"
            ]
          },
          "fonte": {
            "type": "string"
          },
          "righe": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "emotivo": {
            "type": "boolean"
          },
          "ritratto": {
            "type": "string"
          },
          "verso": {}
        }
      }
    },
    "segreti": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "flag"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "flag": {
            "type": "string"
          },
          "hud": {
            "type": "string"
          }
        }
      }
    },
    "finali": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "se",
          "titolo",
          "testo"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "se": {},
          "titolo": {
            "type": "string"
          },
          "testo": {
            "type": "string"
          },
          "nascosto": {
            "type": "boolean"
          }
        }
      }
    },
    "ui": {
      "type": "object",
      "required": [
        "giorni",
        "segretiCompleti",
        "segretiParziali"
      ],
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}