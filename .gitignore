node_modules/
__pycache__/
*.pyc
dist/
package.json
package-lock.json

# Privacy: i dati reali dei clienti non entrano MAI nella repo pubblica.
# I giochi consegnati vivono nella repo privata sempreaddue-giochi (Cloudflare).
