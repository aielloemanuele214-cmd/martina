# Dipendenze e artefatti di build (rigenerabili)
node_modules/
__pycache__/
*.pyc
dist/
package.json
package-lock.json

# Cache locale di wrangler/Cloudflare (rigenerabile, non va versionata)
.wrangler/

# Privacy: i dati reali dei clienti non entrano MAI nella repo pubblica.
# I giochi consegnati vivono nella repo privata sempreaddue-giochi (Cloudflare).
# Qui restano versionati solo i due file d'esempio.
gioco/clienti/*
!gioco/clienti/demo.json
!gioco/clienti/esempio.json

# Pack di prova/scratch (rigenerabili, non vanno versionati)
gioco/packs/test-*/
