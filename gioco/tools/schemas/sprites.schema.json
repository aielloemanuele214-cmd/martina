{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "sheets",
    "personaggi"
  ],
  "properties": {
    "sheets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "asset"
        ],
        "properties": {
          "asset": {
            "type": "string"
          },
          "fw": {
            "type": "integer",
            "minimum": 1
          },
          "fh": {
            "type": "integer",
            "minimum": 1
          },
          "n": {
            "type": "integer",
            "minimum": 1
          },
          "alt": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    },
    "personaggi": {
      "type": "object",
      "required": [
        "player",
        "npc",
        "gatto"
      ],
      "properties": {
        "player": {
          "type": "object",
          "required": [
            "fogli",
            "stati"
          ],
          "properties": {
            "fogli": {
              "type": "object",
              "required": [
                "down",
                "up",
                "left",
                "right"
              ]
            },
            "stati": {
              "type": "object",
              "required": [
                "idle",
                "walk",
                "interact"
              ],
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "frame": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "seq": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "integer",
                      "minimum": 0
                    }
                  },
                  "dur": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "bobFreq": {
                    "type": "number"
                  },
                  "bobAmp": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "npc": {
          "type": "object",
          "required": [
            "foglio"
          ]
        },
        "gatto": {
          "type": "object",
          "required": [
            "foglio"
          ]
        }
      },
      "additionalProperties": {
        "type": "object"
      }
    }
  }
}