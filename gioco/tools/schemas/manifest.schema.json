{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "slug",
    "nome",
    "versione",
    "engine",
    "config"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "nome": {
      "type": "string"
    },
    "descrizione": {
      "type": "string"
    },
    "versione": {
      "type": "string"
    },
    "engine": {
      "type": "string"
    },
    "config": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "story": {
      "type": "string"
    }
  }
}