{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "bounds",
    "colliders",
    "dietroLetto"
  ],
  "properties": {
    "bounds": {
      "type": "object",
      "required": [
        "xMin",
        "xMax",
        "yMin",
        "yMax"
      ],
      "properties": {
        "xMin": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "xMax": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "yMin": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "yMax": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "walk": {
      "type": "object",
      "required": [
        "w",
        "h",
        "data"
      ],
      "properties": {
        "w": {
          "type": "integer"
        },
        "h": {
          "type": "integer"
        },
        "data": {
          "type": "string"
        }
      }
    },
    "colliders": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": [
          "t",
          "pts"
        ],
        "properties": {
          "t": {
            "type": "string"
          },
          "rx": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "pts": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "array",
              "items": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "minItems": 2,
              "maxItems": 2
            }
          }
        }
      }
    },
    "dietroLetto": {
      "type": "object",
      "required": [
        "pts"
      ],
      "properties": {
        "pts": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "array",
            "items": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "minItems": 2,
            "maxItems": 2
          }
        }
      }
    }
  }
}